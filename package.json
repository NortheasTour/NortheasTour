{
  "name": "northeastour-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo do projeto NortheasTour - Planejamento de Roteiros Turísticos Regionais",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "start:backend": "npm run start:dev --workspace=apps/backend",
    "start:frontend": "npm run dev --workspace=apps/frontend",
    "build:backend": "npm run build --workspace=apps/backend",
    "build:frontend": "npm run build --workspace=apps/frontend",
    "build:all": "npm run build --workspaces"
  },
  "author": "Grupo 9",
  "license": "ISC",
  "dependencies": {
    "@nestjs/mapped-types": "^2.1.1",
    "@prisma/client": "^7.8.0",
    "prisma": "^7.8.0"
  }
}
